{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ODS Import Processing Config",
  "type": "object",
  "properties": {
    "url": {
      "type": "string",
      "title": "URL",
      "description": "The URL of the API",
      "pattern": "^https?://.*[^/]$",
      "errorMessage": "The URL must start with http:// or https:// and must not end with a slash",
      "examples": ["https://data.mon-domaine.fr"]
    },
    "account": {
      "type": "object",
      "title": "Le compte pour modifier les settings (processings n'a pas accès au type/id du compte)",
      "layout": {
        "getItems": {
          "url": "/simple-directory/api/accounts",
          "qSearchParam": "q",
          "itemsResults": "data.results",
          "itemTitle": "item.name",
          "itemKey": "item.id",
          "itemValue": "item",
          "itemIcon": "`/simple-directory/api/avatars/${item.type}/${item.id}/avatar.png`"
        }
      },
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    }
  },
  "required": ["url", "account"]
}
