{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ODS Import Processing Config",
  "type": "object",
  "properties": {
    "url": {
      "type": "string",
      "title": "URL",
      "description": "The URL of the API",
      "pattern": "^https?://.*[^/]$",
      "errorMessage": "The URL must start with http:// or https:// and must not end with a slash",
      "examples": ["https://data.mon-domaine.fr"]
    },
    "mode": {
      "type": "string",
      "title": "Mode",
      "enum": ["analyse", "import"],
      "default": "analyse"
    },
    "themes": {
      "type": "array",
      "title": "",
      "layout": {
        "if": "parent.data.mode === 'import'",
        "comp": "list",
        "listEditMode": "inline",
        "density": "compact",
        "getItems": {
          "url": {
            "expr": "parent.data.url ? `${parent.data.url}/api/explore/v2.1/catalog/facets?facet=theme` : undefined",
            "type": "js-eval"
          },
          "itemsResults": "data.facets[0]?.facets",
          "itemKey": "item.value"
        }
      },
      "items": {
        "type": "object",
        "required": ["value", "dataFairThemes"],
        "properties": {
          "value": {
            "type": "string",
            "title": "Thème ODS",
            "readOnly": true,
            "layout": {
              "cols": 6
            }
          },
          "dataFairThemes": {
            "type": "array",
            "title": "Thèmes Data Fair",
            "default": [],
            "layout": {
              "props": {
                "clearable": true
              },
              "cols": 6,
              "getItems": {
                "url": "/data-fair/api/v1/settings/${context.owner.type}/${context.owner.id}/topics",
                "itemsResults": "data",
                "itemKey": "item.title",
                "itemTitle": "item.title",
                "itemIcon": "item.icon?.svg"
              }
            },
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title"],
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "color": {
                  "type": "string"
                },
                "icon": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  },
  "required": ["url", "mode"]
}
