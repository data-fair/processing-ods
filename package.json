{
  "name": "@data-fair/processing-ods",
  "version": "0.2.0",
  "description": "Plugin for data-fair-processings to import datasets from an ODS portal into Data-Fair.",
  "main": "index.ts",
  "scripts": {
    "lint": "eslint .",
    "lint-fix": "eslint --fix .",
    "prepare": "husky || true",
    "build-types": "export NODE_OPTIONS='--experimental-strip-types' && df-build-types ./",
    "test-base": "NODE_ENV=test node --experimental-strip-types --test-force-exit --test-concurrency=1 --test --test-reporter=spec --test-reporter-destination=stdout",
    "test": "npm run test-base test-it/*.ts"
  },
  "imports": {
    "#types/*": "./types/*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/data-fair/processing-ods.git"
  },
  "keywords": [
    "data-fair-processings-plugin"
  ],
  "license": "AGPL-3.0-only",
  "type": "module",
  "bugs": {
    "url": "https://github.com/data-fair/processing-ods/issues"
  },
  "homepage": "https://github.com/data-fair/processing-ods#readme",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@data-fair/lib-common-types": "^1.20.6",
    "@data-fair/lib-processing-dev": "^0.2.0",
    "@data-fair/lib-types-builder": "^1.7.0",
    "@types/node": "^25.5.0",
    "config": "^4.4.1",
    "debug": "^4.4.0",
    "eslint": "^9.26.0",
    "husky": "^9.1.7",
    "neostandard": "^0.12.1",
    "typescript": "^5.8.3",
    "ws": "^8.19.0"
  },
  "files": [
    "processing-config-schema.json",
    "./lib/**/*"
  ],
  "relativeDependencies": {
    "@data-fair/lib-common-types": "../../lib/packages/common-types",
    "@data-fair/lib-processing-dev": "../../lib/packages/processing-dev",
    "@data-fair/lib-utils": "../../lib/packages/utils"
  },
  "dependencies": {
    "@data-fair/lib-utils": "^1.9.0",
    "form-data": "^4.0.5"
  }
}
